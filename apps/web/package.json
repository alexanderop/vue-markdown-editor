{
  "name": "@vme/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p typecheck \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:browser": "vitest run --config vitest.config.browser.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@codemirror/commands": "catalog:",
    "@codemirror/lang-markdown": "catalog:",
    "@codemirror/language-data": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@comark/vue": "catalog:",
    "@vme/ui": "workspace:*",
    "@vueuse/core": "catalog:",
    "codemirror": "catalog:",
    "comark": "catalog:",
    "pinia": "catalog:",
    "shiki": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/vue": "catalog:",
    "@types/jsdom": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vue/tsconfig": "catalog:",
    "axe-core": "catalog:",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "catalog:",
    "vue-tsc": "catalog:"
  }
}
